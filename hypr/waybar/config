[
  {
    "layer": "top",
    "position": "top",
    "height": 44,
    "spacing": 6,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["hyprland/workspaces", "custom/layout", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/updates", "cpu", "memory", "network", "backlight", "battery", "pulseaudio", "tray", "custom/power"],

    "hyprland/workspaces": {
      "all-outputs": true,
      "format": "{id}",
      "disable-scroll": true,
      "sort-by-number": true,
      "on-click": "activate"
    },

    "hyprland/window": {
      "max-length": 24,
      "separate-outputs": true,
      "tooltip": true,
      "rewrite": {
        "(.*) - Google Chrome": "$1",
        "(.*) βÄî Visual Studio Code": "$1",
        "(.*) - YouTube": "YouTube"
      }
    },

    "custom/layout": {
      "exec": "~/.config/waybar/scripts/layout.sh",
      "interval": 2,
      "return-type": "plain",
      "tooltip": "Current tiling layout",
      "on-click": "~/.config/hypr/scripts/layout-switcher.sh toggle"
    },

    "clock": {
      "format": "σΑΞî  {:%a %d %b %H:%M}",
      "tooltip-format": "{:%A, %d %B %Y | %H:%M:%S %Z}"
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "format-icons": {
        "default": "οÉß",
        "performance": "οÉß",
        "balanced": "οâé",
        "power-saver": "ο¹§",
        "unknown": "οâé"
      },
      "tooltip": true
    },

    "custom/weather": {
      "exec": "~/.config/waybar/scripts/weather.sh",
      "interval": 1200,
      "return-type": "plain",
      "tooltip": false
    },

    "custom/vpn": {
      "exec": "~/.config/waybar/scripts/vpn.sh",
      "interval": 8,
      "return-type": "json",
      "tooltip": true,
      "on-click": "nm-connection-editor"
    },

    "custom/updates": {
      "exec": "~/.config/waybar/scripts/updates.sh",
      "interval": 900,
      "return-type": "plain",
      "tooltip": true,
      "tooltip-format": "System updates",
      "on-click": "kitty -e sh -lc 'yay -Syu; read -r -p \"Press enter to close\"'"
    },

    "cpu": {
      "format": "ο£Φ  {usage}%",
      "interval": 3
    },

    "memory": {
      "format": "νâΠ  {}%",
      "interval": 5
    },

    "network": {
      "format-wifi": "ο΅Ϊ   {signalStrength}%",
      "format-ethernet": "σΑàÄ   {ifname}",
      "format-disconnected": "σΑΛ°   down",
      "tooltip-format": "{ifname} {ipaddr}/{cidr}"
    },

    "backlight": {
      "format": "σΑÉ†  {percent}%"
    },

    "battery": {
      "states": {
        "warning": 25,
        "critical": 12
      },
      "format": "{icon}  {capacity}%",
      "format-charging": "σΑ²³  {capacity}%",
      "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-muted": "σΑùü  muted",
      "format-icons": {
        "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
      },
      "on-click": "pavucontrol",
      "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 2%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    },

    "custom/notifications": {
      "exec": "swaync-client -sw -D >/dev/null 2>&1 && echo 'σΑ²¦' || echo 'σΑ²ö'",
      "interval": 2,
      "return-type": "plain",
      "tooltip": true,
      "tooltip-format": "Notifications",
      "on-click": "swaync-client -t",
      "on-click-middle": "~/.config/hypr/scripts/notification-summary.sh copy",
      "on-click-right": "swaync-client -d"
    },

    "tray": {
      "spacing": 8
    },

    "custom/launcher": {
      "format": "σΑΘ΅",
      "tooltip": false,
      "on-click": "~/.config/hypr/scripts/launcher.sh"
    },

    "custom/overview": {
      "format": "σΑçΙ",
      "tooltip": "Workspace overview",
      "on-click": "~/.config/hypr/scripts/workspace-overview-toggle.sh"
    },

    "custom/cliphist": {
      "format": "σ±‰¦",
      "tooltip": "Clipboard history",
      "on-click": "~/.config/hypr/scripts/cliphist-rofi.sh"
    },

    "custom/power": {
      "format": "οÄë",
      "tooltip": false,
      "on-click": "~/.config/hypr/scripts/power-menu.sh",
      "on-click-right": "~/.config/hypr/scripts/power-menu.sh compact",
      "on-click-middle": "~/.config/hypr/scripts/lock.sh"
    }
  }
]
