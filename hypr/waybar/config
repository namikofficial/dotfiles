[
  {
    "layer": "top",
    "position": "top",
    "height": 46,
    "spacing": 8,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,

    "modules-left": ["custom/launcher", "custom/overview", "hyprland/workspaces", "custom/layout", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/notifications", "custom/vpn", "custom/weather", "power-profiles-daemon", "custom/updates", "cpu", "memory", "network", "backlight", "battery", "pulseaudio", "tray", "custom/power"],

    "hyprland/workspaces": {
      "all-outputs": true,
      "format": "{icon}",
      "disable-scroll": true,
      "sort-by-number": true,
      "format-icons": {
        "active": "",
        "default": ""
      },
      "on-click": "activate"
    },

    "hyprland/window": {
      "max-length": 34,
      "separate-outputs": true,
      "tooltip": true,
      "rewrite": {
        "(.*) - Google Chrome": "$1",
        "(.*) — Visual Studio Code": "$1",
        "(.*) - YouTube": "YouTube"
      }
    },

    "custom/layout": {
      "exec": "~/.config/waybar/scripts/layout.sh",
      "interval": 2,
      "return-type": "plain",
      "tooltip": "Current tiling layout",
      "on-click": "~/.config/hypr/scripts/layout-switcher.sh toggle"
    },

    "clock": {
      "format": "󰥔  {:%a %d %b  %H:%M}",
      "tooltip-format": "{:%Y-%m-%d}\n{:%H:%M:%S %Z}"
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "format-icons": {
        "default": "",
        "performance": "",
        "balanced": "",
        "power-saver": "",
        "unknown": ""
      },
      "tooltip": true
    },

    "custom/weather": {
      "exec": "~/.config/waybar/scripts/weather.sh",
      "interval": 1200,
      "return-type": "plain",
      "tooltip": false
    },

    "custom/vpn": {
      "exec": "~/.config/waybar/scripts/vpn.sh",
      "interval": 8,
      "return-type": "plain",
      "tooltip": false,
      "on-click": "nm-connection-editor"
    },

    "custom/updates": {
      "exec": "~/.config/waybar/scripts/updates.sh",
      "interval": 900,
      "return-type": "plain",
      "tooltip": true,
      "tooltip-format": "System updates",
      "on-click": "kitty -e sh -lc 'yay -Syu; read -r -p \"Press enter to close\"'"
    },

    "cpu": {
      "format": "  {usage}%",
      "interval": 3
    },

    "memory": {
      "format": "  {}%",
      "interval": 5
    },

    "network": {
      "format-wifi": "   {signalStrength}%",
      "format-ethernet": "󰈀   {ifname}",
      "format-disconnected": "󰤮   down",
      "tooltip-format": "{ifname} {ipaddr}/{cidr}"
    },

    "backlight": {
      "format": "󰃠  {percent}%"
    },

    "battery": {
      "states": {
        "warning": 25,
        "critical": 12
      },
      "format": "{icon}  {capacity}%",
      "format-charging": "󰂄  {capacity}%",
      "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },

    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-muted": "󰝟  muted",
      "format-icons": {
        "default": ["󰕿", "󰖀", "󰕾"]
      },
      "on-click": "pavucontrol",
      "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 2%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    },

    "custom/notifications": {
      "exec": "swaync-client -sw -D >/dev/null 2>&1 && echo '󰂛' || echo '󰂚'",
      "interval": 2,
      "return-type": "plain",
      "tooltip": true,
      "tooltip-format": "Notifications",
      "on-click": "swaync-client -t",
      "on-click-middle": "~/.config/hypr/scripts/notification-summary.sh copy",
      "on-click-right": "swaync-client -d"
    },

    "tray": {
      "spacing": 8
    },

    "custom/launcher": {
      "format": "󰣇",
      "tooltip": false,
      "on-click": "~/.config/hypr/scripts/launcher.sh"
    },

    "custom/overview": {
      "format": "󰍹",
      "tooltip": "Workspace overview",
      "on-click": "~/.config/hypr/scripts/workspace-overview-toggle.sh"
    },

    "custom/cliphist": {
      "format": "󱘛",
      "tooltip": "Clipboard history",
      "on-click": "~/.config/hypr/scripts/cliphist-rofi.sh"
    },

    "custom/power": {
      "format": "",
      "tooltip": false,
      "on-click": "~/.config/hypr/scripts/power-menu.sh",
      "on-click-right": "~/.config/hypr/scripts/power-menu.sh compact",
      "on-click-middle": "~/.config/hypr/scripts/lock.sh"
    }
  }
]
