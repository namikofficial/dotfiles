[
  {
    "layer": "top",
    "position": "top",
    "height": 44,
    "spacing": 6,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["custom/layout", "hyprland/workspaces", "custom/updates", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/cpu", "custom/memory", "network", "pulseaudio", "backlight", "battery", "custom/media"],

    "hyprland/workspaces": {
      "all-outputs": false,
      "format": "{id}",
      "disable-scroll": true,
      "sort-by": "number",
      "on-click": "activate"
    },

    "hyprland/window": {
      "max-length": 24,
      "separate-outputs": true,
      "tooltip": true,
      "rewrite": {
        "(.*) - Google Chrome": "$1",
        "(.*) βÄî Visual Studio Code": "$1",
        "(.*) - YouTube": "YouTube"
      }
    },

    "custom/layout": {
      "exec": "~/.config/waybar/scripts/layout.sh",
      "interval": 2,
      "return-type": "plain",
      "tooltip": "Current tiling layout",
      "on-click": "~/.config/hypr/scripts/layout-switcher.sh toggle"
    },

    "clock": {
      "format": "σΑΞî  {:%a %d %b %H:%M}",
      "tooltip-format": "<tt><span weight='700'>{:%A, %d %B %Y}</span>\n\n{calendar}</tt>",
      "calendar": {
        "mode": "month",
        "weeks-pos": "",
        "on-scroll": 1,
        "format": {
          "months": "<span weight='700'>  {}  </span>",
          "weekdays": "<span weight='700'>{}</span>",
          "today": "<span weight='700' underline='single'>{}</span>"
        }
      },
      "actions": {
        "on-click-right": "mode",
        "on-click-middle": "mode",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
      }
    },

    "custom/updates": {
      "exec": "~/.config/waybar/scripts/updates.sh",
      "interval": 900,
      "return-type": "plain",
      "tooltip": true,
      "tooltip-format": "System updates",
      "on-click": "kitty -e sh -lc 'yay -Syu; read -r -p \"Press enter to close\"'"
    },

    "custom/media": {
      "exec": "~/.config/waybar/scripts/media.sh",
      "interval": 3,
      "return-type": "json",
      "max-length": 34,
      "tooltip": true,
      "on-click": "~/.config/hypr/scripts/widget-actions.sh music"
    },

    "custom/cpu": {
      "exec": "~/.config/waybar/scripts/cpu-compact.sh",
      "interval": 3,
      "return-type": "json",
      "tooltip": true,
      "on-click": "~/.config/hypr/scripts/open-system-monitor.sh"
    },

    "custom/memory": {
      "exec": "~/.config/waybar/scripts/memory-compact.sh",
      "interval": 3,
      "return-type": "json",
      "tooltip": true,
      "on-click": "~/.config/hypr/scripts/open-system-monitor.sh"
    },

    "network": {
      "format-wifi": "σΑ•© {signalStrength}%",
      "format-ethernet": "σΑàÄ",
      "format-linked": "σΑ¨‰",
      "format-disconnected": "σΑΛ°",
      "tooltip-format": "{ifname}\n{ipaddr}/{cidr}\nSignal: {signalStrength}%",
      "on-click": "nm-connection-editor"
    },

    "battery": {
      "states": {
        "warning": 25,
        "critical": 12
      },
      "format": "{icon} {capacity}%",
      "format-full": "σΑ¹Ι 100%",
      "format-charging": "σΑ²³ {capacity}%",
      "tooltip-format": "Battery {capacity}%\n{timeTo}",
      "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    "backlight": {
      "format": "σΑÉ† {percent}%",
      "tooltip-format": "Brightness {percent}%",
      "on-scroll-up": "~/.config/hypr/scripts/brightness-control.sh up",
      "on-scroll-down": "~/.config/hypr/scripts/brightness-control.sh down"
    },

    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "σΑùü",
      "tooltip-format": "Volume {volume}%",
      "format-icons": {
        "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
      },
      "on-click": "pavucontrol",
      "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 2%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    }
  }
]
