configuration {
    modi: "drun,window,run";
    show-icons: true;
    terminal: "kitty";
    drun-display-format: "{name}";
    disable-history: false;
    hide-scrollbar: true;
    display-drun: " Apps";
    display-run: " Run";
    display-window: " Windows";
    font: "JetBrainsMono Nerd Font 12";
}

@theme "theme.rasi"
