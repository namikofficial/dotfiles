{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "cssPriority": "application",
  "notification-2fa-action": true,
  "notification-window-width": 420,
  "relative-timestamps": true,
  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 520,
  "control-center-height": 720,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 180,
  "hide-on-clear": true,
  "hide-on-action": true,
  "notification-visibility": {
    "all-popups-enabled": {
      "state": "enabled",
      "app-name": ".*"
    },
    "hyprland-popups-enabled": {
      "state": "enabled",
      "app-name": "Hyprland"
    }
  },
  "scripts": {
    "play-notify-critical": {
      "exec": "sh -lc '$HOME/.config/hypr/scripts/notify-sound.sh critical'",
      "urgency": "Critical",
      "run-on": "receive"
    },
    "play-notify-message": {
      "exec": "sh -lc '$HOME/.config/hypr/scripts/notify-sound.sh message'",
      "app-name": "(Telegram|org\\.telegram\\.desktop|Discord|discord|Slack|slack|Signal|signal|Element|element-desktop|WhatsApp|vesktop)",
      "run-on": "receive"
    },
    "play-notify-system": {
      "exec": "sh -lc '$HOME/.config/hypr/scripts/notify-sound.sh system'",
      "app-name": "(Hyprland|NetworkManager|nm-applet|blueman|Udiskie|powerprofilesctl|Power|systemd|Kernel|Bluetooth|WirePlumber|PipeWire)",
      "run-on": "receive"
    }
  },
  "widgets": [
    "title",
    "buttons-grid#notif_tools",
    "label#status_header",
    "buttons-grid#status_grid",
    "buttons-grid#actions_grid",
    "dnd",
    "mpris",
    "volume",
    "backlight",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "\udb80\udec3"
    },
    "buttons-grid#notif_tools": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "\udb80\udfe2 Copy Hub",
          "command": "sh -lc '$HOME/.config/hypr/scripts/notification-summary.sh copy'"
        },
        {
          "label": "\udb80\uddb4 Clear All",
          "command": "swaync-client -C"
        }
      ]
    },
    "label#status_header": {
      "text": "System Hub"
    },
    "buttons-grid#status_grid": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "\udb82\udcae GPU Active",
          "command": "sh -lc '$HOME/.config/hypr/scripts/notification-summary.sh popup'",
          "type": "toggle",
          "update-command": "sh -lc '$HOME/.config/hypr/scripts/status-gpu-active.sh'"
        },
        {
          "label": "\udb81\udc0a Media Active",
          "command": "playerctl play-pause",
          "type": "toggle",
          "update-command": "sh -lc '$HOME/.config/hypr/scripts/status-media-active.sh'"
        },
        {
          "label": "\udb81\udda9 Network Online",
          "command": "nm-connection-editor",
          "type": "toggle",
          "update-command": "sh -lc '$HOME/.config/hypr/scripts/status-network-online.sh'"
        },
        {
          "label": "\udb80\udf79 Panel Visible",
          "command": "sh -lc '$HOME/.config/hypr/scripts/panel-switch.sh toggle-view'",
          "type": "toggle",
          "update-command": "sh -lc '$HOME/.config/hypr/scripts/status-panel-visible.sh'"
        }
      ]
    },
    "buttons-grid#actions_grid": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "\udb85\udc0b Toggle DND",
          "command": "swaync-client -d",
          "type": "toggle",
          "update-command": "sh -lc '$HOME/.config/hypr/scripts/status-dnd.sh'"
        },
        {
          "label": "\udb82\udecc Desktop Widgets",
          "command": "sh -lc '$HOME/.config/hypr/scripts/eww-desktop-toggle.sh'",
          "type": "toggle",
          "update-command": "sh -lc '$HOME/.config/hypr/scripts/status-desktop-widgets.sh'"
        },
        {
          "label": "\udb81\uddaa Net Applet",
          "command": "sh -lc '$HOME/.config/hypr/scripts/nm-applet-toggle.sh'",
          "type": "toggle",
          "update-command": "sh -lc 'pgrep -x nm-applet >/dev/null && echo true || echo false'"
        },
        {
          "label": "\udb81\udd6e Panel View",
          "command": "sh -lc '$HOME/.config/hypr/scripts/panel-switch.sh toggle-view'"
        },
        {
          "label": "\udb81\udda8 Restart Bar",
          "command": "sh -lc '$HOME/.config/hypr/scripts/restart-waybar.sh'"
        }
      ]
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "autohide": false,
      "show-album-art": "when-available"
    },
    "volume": {
      "label": "Volume",
      "show-per-app": true,
      "expand-per-app": false
    },
    "backlight": {
      "label": "Brightness"
    },
    "notifications": {
      "show-scrollbar": true,
      "vexpand": true
    }
  }
}
